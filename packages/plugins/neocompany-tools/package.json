{
  "name": "@paperclipai/plugin-neocompany-tools",
  "version": "0.1.0",
  "description": "NeoCompany tools plugin for Paperclip — SEO, WordPress, social media, email, and content tools exposed to OpenClaw agents",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./src/index.ts"
  },
  "paperclipPlugin": {
    "manifest": "./dist/manifest.js",
    "worker": "./dist/worker.js",
    "ui": "./dist/ui/"
  },
  "scripts": {
    "prebuild": "node ../../../scripts/ensure-plugin-build-deps.mjs",
    "build": "tsc && node ./scripts/build-ui.mjs",
    "clean": "rm -rf dist",
    "typecheck": "pnpm --filter @paperclipai/plugin-sdk build && tsc --noEmit"
  },
  "dependencies": {
    "@paperclipai/plugin-sdk": "workspace:*",
    "imapflow": "^1.0.196",
    "mailparser": "^3.7.4",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/mailparser": "^3.4.5",
    "@types/node": "^24.6.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "esbuild": "^0.27.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.3"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "license": "MIT"
}
